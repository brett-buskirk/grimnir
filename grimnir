#!/usr/bin/env bash
# grimnir — the Allfather's high seat. Marshals the estate's beasts (huginn/muninn/geri/freki)
# from $GRIMNIR_ROOT (default ~/github-repos) into one consolidated view. Odin's byname — "the
# masked one" — sees into all realms from Hliðskjálf at once. The point is consolidation, not
# aliasing: every command here does something none of the four beasts can do alone.
#
#   grimnir survey | brief | summon | rally | install | config | schedule | doctor | version
#   run 'grimnir help' for the menu, or 'grimnir <command> help' for per-command detail.
# shellcheck disable=SC2059  # color vars are fixed ANSI codes, deliberately embedded in format strings
set -uo pipefail
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; HERE="$(cd "$(dirname "$SELF")" && pwd)"

# ── configuration — env  >  config file  >  huginn's config  >  smart defaults ────────────
CONFIG="${GRIMNIR_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/grimnir/config}"
for _v in ROOT OWNER; do eval "_env_$_v=\${GRIMNIR_$_v-}"; done
# shellcheck disable=SC1090
[ -f "$CONFIG" ] && . "$CONFIG"

# free config for huginn users — if GRIMNIR_* is unset, fall back to huginn's config
HCONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/huginn/config"
# shellcheck disable=SC1090
[ -f "$HCONFIG" ] && . "$HCONFIG"

ROOT="${_env_ROOT:-${GRIMNIR_ROOT:-${HUGINN_ROOT:-$HOME/github-repos}}}"
OWNER="${_env_OWNER:-${GRIMNIR_OWNER:-${HUGINN_OWNER:-}}}"   # each beast resolves this lazily itself
CONV="$ROOT/${GRIMNIR_CONVENTIONS:-${HUGINN_CONVENTIONS:-repo-conventions}}"   # dir with exemptions.json (shared estate standard)
BIN="${GRIMNIR_BIN:-$HOME/.local/bin}"                 # where beast scripts get symlinked
PACK_OWNER="${GRIMNIR_PACK_OWNER:-brett-buskirk}"      # canonical source of the beast repos (not necessarily the estate owner)
BEASTS="huginn muninn geri freki"                      # the four beasts grimnir commands (grimnir itself is the seat)
SCHED_BEGIN="# >>> grimnir schedule >>>"; SCHED_END="# <<< grimnir schedule <<<"   # the crontab block grimnir manages

# shellcheck disable=SC2034  # M (magenta) is part of the shared huginn/muninn/geri/freki palette; unused in grimnir for now
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; C=$'\e[36m'; M=$'\e[35m'; DIM=$'\e[2m'; BD=$'\e[1m'; X=$'\e[0m'
else R=; G=; Y=; C=; M=; DIM=; BD=; X=; fi

is_help(){ case "${1:-}" in help|-h|--help) return 0;; *) return 1;; esac; }
have(){ command -v "$1" >/dev/null 2>&1; }
plural(){ [ "${1:-0}" = 1 ] && printf '' || printf 's'; }
need_owner(){ [ -n "$OWNER" ] && return 0; OWNER="$(gh api user --jq .login 2>/dev/null)"; [ -n "$OWNER" ] && return 0; printf "  ${R}no GitHub owner set.${X} Set GRIMNIR_OWNER, add it to %s, or set HUGINN_OWNER in ~/.config/huginn/config.\n" "$CONFIG" >&2; return 1; }
need_deps(){ local d; local -a miss=(); for d in git gh jq; do have "$d" || miss+=("$d"); done; [ ${#miss[@]} -eq 0 ] && return 0; printf "  ${R}missing required tool(s): %s${X} ${DIM}(grimnir needs bash, git, gh, jq)${X}\n" "${miss[*]}" >&2; return 1; }
# pull the first capture group of a regex out of a block of text — used to lift a headline
# number back out of a beast's own (already-rendered) summary line
grab(){ [[ "$2" =~ $1 ]] && printf '%s' "${BASH_REMATCH[1]}" || printf ''; }
first_of(){ local f; for f in "$@"; do [ -e "$f" ] && { printf '%s' "$f"; return 0; }; done; return 1; }  # your file, else the bundled one
# collapse a leading $HOME back to the literal, so a written config reads like the beasts' configs
# shellcheck disable=SC2016  # the literal '$HOME' is intentional — we want the token, not its value
homelit(){ case "$1" in "$HOME"/*) printf '$HOME/%s' "${1#"$HOME"/}";; "$HOME") printf '$HOME';; *) printf '%s' "$1";; esac; }
# write grimnir's config with detected defaults (shared by 'config init' and 'install')
write_config(){
  mkdir -p "$(dirname "$CONFIG")"
  local o; o="${OWNER:-$(gh api user --jq .login 2>/dev/null)}"
  cat > "$CONFIG" <<CFG
# grimnir configuration — https://github.com/brett-buskirk/grimnir
GRIMNIR_OWNER="$o"
GRIMNIR_ROOT="$(homelit "$ROOT")"
CFG
}
# set-or-replace a KEY="value" line in the config file (| delimiter dodges path slashes)
upsert_config(){
  local key="$1" val="$2" tmp
  if grep -q "^$key=" "$CONFIG" 2>/dev/null; then
    tmp="$(mktemp)"; sed "s|^$key=.*|$key=\"$val\"|" "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"
  else printf '%s="%s"\n' "$key" "$val" >> "$CONFIG"; fi
}

# ── pack provisioning (shared by install & rally) ─────────────────────────
# print the dep line; return non-zero if any of bash/git/gh/jq is missing
deps_report(){
  local d bad=0
  printf "  ${BD}deps${X}  "
  for d in bash git gh jq; do
    if have "$d"; then printf "${G}✓${X} %s  " "$d"; else printf "${R}✗ %s${X}  " "$d"; bad=1; fi
  done
  printf "\n"
  return "$bad"
}
# symlink one pack member's script into $BIN. Prints a status line; return buckets the outcome:
#   0 linked (new) · 1 already linked · 2 absent (no repo) · 3 conflict (points elsewhere) · 4 failed
link_one(){
  local name="$1" dry="$2" force="$3"
  local script="$ROOT/$name/$name" link="$BIN/$name" tgt
  [ -f "$script" ] || { printf "    ${DIM}∙ %-8s repo not in estate — skipping${X}\n" "$name"; return 2; }
  if [ -L "$link" ] || [ -e "$link" ]; then
    tgt="$(readlink -f "$link" 2>/dev/null)"
    if [ "$tgt" = "$(readlink -f "$script")" ]; then
      printf "    ${G}✓${X} %-8s ${DIM}already linked${X}\n" "$name"; return 1
    fi
    if [ "$force" != 1 ]; then
      printf "    ${Y}▲${X} %-8s ${DIM}%s exists → %s (pass --force to relink)${X}\n" "$name" "$(homelit "$link")" "${tgt:-?}"; return 3
    fi
  fi
  if [ "$dry" = 1 ]; then
    printf "    ${C}+ would link${X} %-8s ${DIM}→ %s${X}\n" "$name" "$(homelit "$script")"; return 0
  fi
  mkdir -p "$BIN"
  if ln -sf "$script" "$link"; then
    printf "    ${G}✓ linked${X}   %-8s ${DIM}→ %s${X}\n" "$name" "$(homelit "$script")"; return 0
  fi
  printf "    ${R}✗ failed to link %s${X}\n" "$name"; return 4
}
# the local wiring — deps · symlink the pack · scaffold config · PATH note. Tallies into P_* globals.
provision(){
  local dry="$1" force="$2" name rc
  deps_report || printf "    ${Y}install the missing tool(s) before the pack will fully work${X}\n"
  printf "\n  ${BD}link${X} ${DIM}(symlink each present script → %s)${X}\n" "$(homelit "$BIN")"
  P_LINKED=0; P_ALREADY=0; P_ABSENT=0; P_CONFLICT=0; P_FAILED=0
  for name in grimnir $BEASTS; do
    link_one "$name" "$dry" "$force"; rc=$?
    case "$rc" in
      0) P_LINKED=$((P_LINKED+1));; 1) P_ALREADY=$((P_ALREADY+1));; 2) P_ABSENT=$((P_ABSENT+1));;
      3) P_CONFLICT=$((P_CONFLICT+1));; 4) P_FAILED=$((P_FAILED+1));;
    esac
  done
  printf "\n  ${BD}config${X}\n"
  if [ -f "$CONFIG" ]; then printf "    ${G}✓${X} %s ${DIM}(exists)${X}\n" "$(homelit "$CONFIG")"
  elif [ "$dry" = 1 ]; then printf "    ${C}+ would scaffold %s${X}\n" "$(homelit "$CONFIG")"
  else write_config && printf "    ${G}✓${X} scaffolded %s\n" "$(homelit "$CONFIG")"; fi
  case ":$PATH:" in
    *":$BIN:"*) : ;;
    *) printf "\n  ${Y}note:${X} %s is not on your \$PATH — add it so the pack is callable.\n" "$(homelit "$BIN")";;
  esac
}
# echo "<latest-tag>\x1f<commits-since-tag>" for a pack member; tag empty if untagged.
# return 1 (no output) when the repo isn't in the estate — derive version from tags, don't store it.
# \x1f (not a tab) so an empty leading field — an untagged repo — survives 'read' (see muninn's note).
beast_ver(){
  local dir="$ROOT/$1"
  [ -d "$dir/.git" ] || return 1
  local t ahead=0; t="$(git -C "$dir" tag --sort=-v:refname 2>/dev/null | head -1)"
  [ -n "$t" ] && ahead="$(git -C "$dir" rev-list --count "$t"..HEAD 2>/dev/null || echo 0)"
  printf '%s\x1f%s' "$t" "$ahead"
}

# ── survey (the flagship — one consolidated all-realms briefing) ─────────
cmd_survey(){
  is_help "${1:-}" && { help_survey; return 0; }
  printf "\n  ${BD}grimnir survey${X}  ${DIM}· consolidated estate briefing · %s · %s${X}\n" "$ROOT" "$(date '+%a %b %-d, %H:%M')"

  local any=0
  local -a headline=()

  # ── present — huginn: state + convention compliance ──────────────────────
  if have huginn; then
    any=1
    printf "\n  ${C}${BD}── present ──${X}\n"
    local status_out; status_out="$(huginn status 2>&1)"
    printf '%s\n' "$status_out"
    local dirty; dirty="$(grab '([0-9]+) dirty' "$status_out")"
    [ -n "$dirty" ] && [ "$dirty" != 0 ] && headline+=("${dirty} dirty")

    local doctor_out; doctor_out="$(huginn doctor 2>&1)"
    printf '%s\n' "$doctor_out"
    local gaps; gaps="$(grab '([0-9]+) with gaps' "$doctor_out")"
    [ -n "$gaps" ] && [ "$gaps" != 0 ] && headline+=("${gaps} compliance gap$(plural "$gaps")")
  else
    printf "\n  ${DIM}huginn not installed — skipping present state${X}\n"
  fi

  # ── past — muninn: what shipped lately ────────────────────────────────────
  if have muninn; then
    any=1
    printf "\n  ${C}${BD}── past ──${X}\n"
    muninn digest --since 1w
  else
    printf "\n  ${DIM}muninn not installed — skipping past${X}\n"
  fi

  # ── threats — geri: alerts · deps · actions ───────────────────────────────
  if have geri; then
    any=1
    printf "\n  ${C}${BD}── threats ──${X}\n"
    local hunt_out; hunt_out="$(geri hunt 2>&1)"
    printf '%s\n' "$hunt_out"
    local alerts; alerts="$(grab '([0-9]+) alert' "$hunt_out")"
    [ -n "$alerts" ] && [ "$alerts" != 0 ] && headline+=("${alerts} alert$(plural "$alerts")")
  else
    printf "\n  ${DIM}geri not installed — skipping threats${X}\n"
  fi

  # ── cruft — freki: the dry-run reap summary ───────────────────────────────
  if have freki; then
    any=1
    printf "\n  ${C}${BD}── cruft ──${X}\n"
    local reap_out; reap_out="$(freki reap 2>&1)"
    printf '%s\n' "$reap_out"
    local reapable; reapable="$(grab '([0-9]+) thing' "$reap_out")"
    [ -n "$reapable" ] && [ "$reapable" != 0 ] && headline+=("${reapable} reapable")
  else
    printf "\n  ${DIM}freki not installed — skipping cruft${X}\n"
  fi

  if [ "$any" -eq 0 ]; then
    printf "\n  ${R}no beasts installed${X} ${DIM}— nothing to survey (huginn/muninn/geri/freki all missing from PATH)${X}\n\n"
    return 0
  fi

  printf "\n  ${BD}estate:${X}"
  if [ "${#headline[@]}" -eq 0 ]; then printf "  ${G}all clear${X}\n\n"
  else
    local i
    for i in "${!headline[@]}"; do
      [ "$i" -gt 0 ] && printf " ${DIM}·${X}"
      printf " %s" "${headline[$i]}"
    done
    printf "\n\n"
  fi
}

# ── per-command help ──────────────────────────────────────────────────────
help_survey(){
  printf "\n  ${BD}grimnir survey${X}\n\n"
  printf "  The flagship — one consolidated all-realms briefing, marshaling every installed\n"
  printf "  beast into a single view:\n\n"
  printf "    ${BD}present${X}    huginn status (state) + huginn doctor (compliance summary)\n"
  printf "    ${BD}past${X}       muninn digest --since 1w (what shipped lately)\n"
  printf "    ${BD}threats${X}    geri hunt (alerts · deps · actions)\n"
  printf "    ${BD}cruft${X}      freki reap (dry-run cruft summary)\n\n"
  printf "  Each section runs under a labeled heading; a beast missing from PATH is skipped\n"
  printf "  with a quiet note rather than failing the whole survey. Closes with a top-line\n"
  printf "  ${BD}estate:${X} headline synthesized from whatever ran (dirty repos, compliance gaps,\n"
  printf "  open alerts, reapable cruft) — ${G}all clear${X} when every number is zero.\n\n"
  printf "  ${DIM}Network — this runs the heaviest command each installed beast has (huginn doctor,\n"
  printf "  geri hunt, freki reap); a full sweep can take a minute or two on a big estate.${X}\n\n"
}

# ── brief / morning (the deltas since last brief — a lean daily digest) ────
# annotate a metric with its change vs the prior snapshot (▲ up / ▼ down / — flat).
# empty prev = first run → no annotation. Increases in threats/cruft read as attention (yellow).
brief_delta(){
  local prev="$1" cur="$2" d
  [ -z "$prev" ] && return 0
  d=$((cur - prev))
  if   [ "$d" -gt 0 ]; then printf "${Y}▲ +%d${X}" "$d"
  elif [ "$d" -lt 0 ]; then printf "${G}▼ %d${X}" "$d"
  else printf "${DIM}—${X}"; fi
}
# turn "time since last brief" into a muninn --since window (Nh under 2 days, else Nd); 1d on first run
brief_window(){
  local prev="$1" now="$2" secs
  [ -z "$prev" ] && { printf '1d'; return; }
  secs=$((now - prev)); [ "$secs" -lt 3600 ] && secs=3600
  if [ "$secs" -lt 172800 ]; then printf '%dh' $(( secs/3600 + 1 )); else printf '%dd' $(( secs/86400 + 1 )); fi
}
cmd_brief(){
  is_help "${1:-}" && { help_brief; return 0; }
  local SAVE=1 SINCE=""
  while [ $# -gt 0 ]; do case "$1" in
    --no-save)  SAVE=0;;
    --since)    shift; SINCE="${1:-}";;
    -*)         printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
    *)          printf "  ${Y}ignoring unexpected argument: %s${X}\n" "$1";;
  esac; shift; done

  local STATEDIR="${XDG_STATE_HOME:-$HOME/.local/state}/grimnir" STATE
  STATE="$STATEDIR/brief-state"

  # load the prior snapshot (locals pre-declared so 'set -u' + a partial file are both safe)
  local GRIMNIR_BRIEF_TS="" GRIMNIR_BRIEF_ALERTS="" GRIMNIR_BRIEF_DEPS="" GRIMNIR_BRIEF_ACTIONS="" GRIMNIR_BRIEF_REAPABLE=""
  # shellcheck disable=SC1090
  [ -f "$STATE" ] && . "$STATE"
  local prev_ts="$GRIMNIR_BRIEF_TS" prev_alerts="$GRIMNIR_BRIEF_ALERTS" prev_deps="$GRIMNIR_BRIEF_DEPS"
  local prev_actions="$GRIMNIR_BRIEF_ACTIONS" prev_reap="$GRIMNIR_BRIEF_REAPABLE"

  local now prevdate; now="$(date +%s)"
  prevdate="$([ -n "$prev_ts" ] && date -d "@$prev_ts" '+%a %b %-d' || echo 'first run')"
  printf "\n  ${BD}grimnir brief${X}  ${DIM}· deltas since %s · %s${X}\n" "$prevdate" "$(date '+%a %b %-d, %H:%M')"

  # current values start at the prior — so a beast that's absent this run keeps its baseline
  local cur_alerts="$prev_alerts" cur_deps="$prev_deps" cur_actions="$prev_actions" cur_reap="$prev_reap"
  local any=0; local -a headline=()

  # ── threats (geri) ── parse the counts off geri hunt's summary line, not the per-repo rows
  if have geri; then
    any=1
    local hunt sumline; hunt="$(geri hunt 2>&1)"
    sumline="$(printf '%s\n' "$hunt" | grep 'unpinned action' | tail -1)"
    cur_alerts="$(grab '([0-9]+) alert' "$sumline")"; : "${cur_alerts:=0}"
    cur_deps="$(grab '([0-9]+) outdated dep signal' "$sumline")"; : "${cur_deps:=0}"
    cur_actions="$(grab '([0-9]+) unpinned action' "$sumline")"; : "${cur_actions:=0}"
    printf "\n  ${C}${BD}── threats ──${X}\n"
    printf "    ${BD}alerts${X}   %4s   %s\n" "$cur_alerts"  "$(brief_delta "$prev_alerts"  "$cur_alerts")"
    printf "    ${BD}deps${X}     %4s   %s\n" "$cur_deps"    "$(brief_delta "$prev_deps"    "$cur_deps")"
    printf "    ${BD}actions${X}  %4s   %s\n" "$cur_actions" "$(brief_delta "$prev_actions" "$cur_actions")"
    if [ -n "$prev_alerts" ]; then
      local da=$((cur_alerts - prev_alerts));   [ "$da" -gt 0 ] && headline+=("${da} new alert$(plural "$da")")
      local dd=$(( (cur_deps - prev_deps) + (cur_actions - prev_actions) )); [ "$dd" -gt 0 ] && headline+=("${dd} fresh drift")
    fi
  else
    printf "\n  ${DIM}geri not installed — skipping threats${X}\n"
  fi

  # ── cruft (freki) ──
  if have freki; then
    any=1
    local reap; reap="$(freki reap 2>&1)"
    cur_reap="$(grab '([0-9]+) thing' "$reap")"; : "${cur_reap:=0}"
    printf "\n  ${C}${BD}── cruft ──${X}\n"
    printf "    ${BD}reapable${X} %4s   %s\n" "$cur_reap" "$(brief_delta "$prev_reap" "$cur_reap")"
    if [ -n "$prev_reap" ]; then
      local dr=$((cur_reap - prev_reap)); [ "$dr" -gt 0 ] && headline+=("${dr} more reapable")
    fi
  else
    printf "\n  ${DIM}freki not installed — skipping cruft${X}\n"
  fi

  # ── shipped (muninn) ── the window since your last brief (override with --since)
  if have muninn; then
    any=1
    local win="$SINCE"; [ -z "$win" ] && win="$(brief_window "$prev_ts" "$now")"
    printf "\n  ${C}${BD}── shipped ──${X} ${DIM}(since %s)${X}\n" "$win"
    muninn digest --since "$win"
  else
    printf "\n  ${DIM}muninn not installed — skipping shipped${X}\n"
  fi

  if [ "$any" -eq 0 ]; then
    printf "\n  ${R}no beasts installed${X} ${DIM}— nothing to brief (geri/freki/muninn all missing)${X}\n\n"
    return 0
  fi

  # ── headline ──
  printf "\n  ${BD}brief:${X}"
  if [ -z "$prev_ts" ]; then printf "  ${DIM}baseline saved — deltas start next run${X}"
  elif [ "${#headline[@]}" -eq 0 ]; then printf "  ${G}all quiet since %s${X}" "$prevdate"
  else local i; for i in "${!headline[@]}"; do [ "$i" -gt 0 ] && printf " ${DIM}·${X}"; printf " %s" "${headline[$i]}"; done; fi
  printf "\n"

  # ── save the new snapshot (unless peeking) ──
  if [ "$SAVE" = 1 ]; then
    mkdir -p "$STATEDIR"
    cat > "$STATE" <<EOF_STATE
GRIMNIR_BRIEF_TS=$now
GRIMNIR_BRIEF_ALERTS=${cur_alerts:-0}
GRIMNIR_BRIEF_DEPS=${cur_deps:-0}
GRIMNIR_BRIEF_ACTIONS=${cur_actions:-0}
GRIMNIR_BRIEF_REAPABLE=${cur_reap:-0}
EOF_STATE
  else
    printf "  ${DIM}--no-save: baseline left at %s${X}\n" "$prevdate"
  fi
  printf "\n"
}

help_brief(){
  printf "\n  ${BD}grimnir brief${X} [--since <window>] [--no-save]  ${DIM}(alias: morning)${X}\n\n"
  printf "  A lean daily digest — what ${BD}changed${X} since your last brief, not the whole estate\n"
  printf "  (${BD}grimnir survey${X} is the full view). Runs the fast-moving beasts and diffs their\n"
  printf "  numbers against a saved snapshot:\n\n"
  printf "    ${BD}threats${X}  geri — alerts · dep/action drift ${DIM}(${X}${Y}▲${X}${DIM} up · ${X}${G}▼${X}${DIM} down since last brief)${X}\n"
  printf "    ${BD}cruft${X}    freki — reapable count, and whether it grew\n"
  printf "    ${BD}shipped${X}  muninn digest for the window since your last brief\n\n"
  printf "  Closes with a headline of what's new; ${G}all quiet${X} when nothing moved. The first run\n"
  printf "  saves a baseline (no deltas yet); a beast that's absent is skipped and keeps its prior\n"
  printf "  snapshot value. Built to run each morning — from cron, or by hand.\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --since <window>  override the 'shipped' window (e.g. 1d, 3d, 1w); default is the\n"
  printf "                      elapsed time since your last brief\n"
  printf "    --no-save         peek without advancing the baseline (deltas stay measured from\n"
  printf "                      the same point next time)\n\n"
  printf "  ${DIM}State: \${XDG_STATE_HOME:-~/.local/state}/grimnir/brief-state. Network — a geri hunt +\n"
  printf "  freki reap + muninn digest, the same cost class as survey.${X}\n\n"
}

# ── schedule (cron the pack's routines) ───────────────────────────────────
# emit the crontab block grimnir manages. A daily brief always; digest/hunt opt-in.
# $PATH is written literally so cron's shell prepends $BIN at run time (cron's PATH is bare).
schedule_block(){
  local mm="$1" hh="$2" digest="$3" hunt="$4" sd="$5"
  local pfx="PATH=$BIN:\$PATH"
  printf '%s\n' "$SCHED_BEGIN"
  printf "%s\n" "# managed by 'grimnir schedule' — edit via that, not by hand"
  printf '%d %d * * *  %s %s/grimnir brief >> %s/brief.log 2>&1\n' "$mm" "$hh" "$pfx" "$BIN" "$sd"
  [ "$digest" = 1 ] && printf '0 8 * * 1  %s %s/muninn digest >> %s/digest.log 2>&1\n' "$pfx" "$BIN" "$sd"
  [ "$hunt" = 1 ]   && printf '0 6 * * *  %s %s/geri hunt >> %s/hunt.log 2>&1\n' "$pfx" "$BIN" "$sd"
  printf '%s\n' "$SCHED_END"
}
# print only the runnable (non-comment) lines of grimnir's current block, one per line
schedule_current(){ crontab -l 2>/dev/null | sed -n "/^$SCHED_BEGIN$/,/^$SCHED_END$/p"; }

cmd_schedule(){
  is_help "${1:-}" && { help_schedule; return 0; }
  local sub="${1:-show}"; [ $# -gt 0 ] && shift
  case "$sub" in
    show)    schedule_show;;
    install) schedule_install "$@";;
    remove)  schedule_remove "$@";;
    *)       printf "  ${R}unknown schedule subcommand: %s${X} ${DIM}(show · install · remove)${X}\n" "$sub"; return 1;;
  esac
}

schedule_show(){
  have crontab || { printf "  ${R}crontab not found${X} ${DIM}(install cron to schedule routines)${X}\n"; return 1; }
  printf "\n  ${BD}grimnir schedule${X}  ${DIM}· the pack's cron routines${X}\n\n"
  local block; block="$(schedule_current)"
  if [ -z "$block" ]; then
    printf "  ${DIM}nothing scheduled — 'grimnir schedule install' sets up a daily brief${X}\n\n"; return 0
  fi
  printf '%s\n' "$block" | grep -v '^#' | while IFS= read -r l; do [ -n "$l" ] && printf "    ${C}%s${X}\n" "$l"; done
  printf "\n  ${DIM}manage with 'grimnir schedule install' / 'grimnir schedule remove'${X}\n\n"
}

schedule_install(){
  have crontab || { printf "  ${R}crontab not found${X} ${DIM}(install cron to schedule routines)${X}\n"; return 1; }
  local DRY=0 DIGEST=0 HUNT=0 hh=7 mm=0 at
  while [ $# -gt 0 ]; do case "$1" in
    --dry-run|-n)    DRY=1;;
    --weekly-digest) DIGEST=1;;
    --daily-hunt)    HUNT=1;;
    --at)            shift; at="${1:-}"
                     if [[ "$at" =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
                       hh=$((10#${BASH_REMATCH[1]})); mm=$((10#${BASH_REMATCH[2]}))
                       { [ "$hh" -gt 23 ] || [ "$mm" -gt 59 ]; } && { printf "  ${Y}--at out of range (%s) — using 07:00${X}\n" "$at"; hh=7; mm=0; }
                     else printf "  ${Y}--at wants HH:MM, e.g. 07:00 — using 07:00${X}\n"; hh=7; mm=0; fi;;
    -*)              printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
  esac; shift; done

  local STATEDIR="${XDG_STATE_HOME:-$HOME/.local/state}/grimnir" block
  block="$(schedule_block "$mm" "$hh" "$DIGEST" "$HUNT" "$STATEDIR")"

  printf "\n  ${BD}grimnir schedule install${X}  ${DIM}· cron the pack's routines%s${X}\n\n" "$([ "$DRY" = 1 ] && echo ' · dry-run')"
  printf '%s\n' "$block" | grep -v '^#' | while IFS= read -r l; do [ -n "$l" ] && printf "    ${C}%s${X}\n" "$l"; done

  if [ "$DRY" = 1 ]; then
    printf "\n  ${DIM}[dry-run] crontab unchanged — drop --dry-run to install.${X}\n\n"; return 0
  fi

  mkdir -p "$STATEDIR"   # so the log redirects have somewhere to write
  if { crontab -l 2>/dev/null | sed "/^$SCHED_BEGIN$/,/^$SCHED_END$/d"; printf '%s\n' "$block"; } | crontab -; then
    printf "\n  ${G}✓${X} installed to your crontab ${DIM}· output → %s/*.log${X}\n" "$(homelit "$STATEDIR")"
    printf "  ${DIM}jobs fire only while the cron service runs — on WSL/containers: 'sudo service cron start'.${X}\n\n"
  else
    printf "\n  ${R}✗ crontab update failed${X}\n\n"; return 1
  fi
}

schedule_remove(){
  have crontab || { printf "  ${R}crontab not found${X}\n"; return 1; }
  local DRY=0 a; for a in "$@"; do case "$a" in --dry-run|-n) DRY=1;; esac; done
  printf "\n  ${BD}grimnir schedule remove${X}%s\n\n" "$([ "$DRY" = 1 ] && echo '  ·  dry-run')"
  local block; block="$(schedule_current)"
  if [ -z "$block" ]; then printf "  ${DIM}nothing scheduled by grimnir${X}\n\n"; return 0; fi
  printf '%s\n' "$block" | grep -v '^#' | while IFS= read -r l; do [ -n "$l" ] && printf "    ${DIM}%s${X}\n" "$l"; done
  if [ "$DRY" = 1 ]; then printf "\n  ${DIM}[dry-run] crontab unchanged.${X}\n\n"; return 0; fi
  if crontab -l 2>/dev/null | sed "/^$SCHED_BEGIN$/,/^$SCHED_END$/d" | crontab -; then
    printf "\n  ${G}✓${X} removed grimnir's cron lines ${DIM}(your other cron jobs untouched)${X}\n\n"
  else
    printf "\n  ${R}✗ crontab update failed${X}\n\n"; return 1
  fi
}

help_schedule(){
  printf "\n  ${BD}grimnir schedule${X} [show | install [opts] | remove] ${DIM}[--dry-run]${X}\n\n"
  printf "  Cron the pack's routines so they run on their own. By default ${BD}install${X} adds one job —\n"
  printf "  a daily ${BD}grimnir brief${X} — whose output appends to a logfile under\n"
  printf "  ${DIM}\${XDG_STATE_HOME:-~/.local/state}/grimnir/${X} (cron has no terminal, so output goes to a\n"
  printf "  file, not your screen). grimnir manages only its own block in your crontab, delimited by\n"
  printf "  ${DIM}'%s'${X} markers — your other cron jobs are never touched.\n\n" "$SCHED_BEGIN"
  printf "  ${BD}Subcommands${X}\n"
  printf "    show ${DIM}(default)${X}    print grimnir's current cron entries\n"
  printf "    install          add them ${DIM}(idempotent — replaces grimnir's existing block)${X}\n"
  printf "    remove           delete grimnir's block, leaving the rest of your crontab intact\n\n"
  printf "  ${BD}install options${X}\n"
  printf "    --at HH:MM        time of day for the daily brief ${DIM}(default 07:00)${X}\n"
  printf "    --weekly-digest   also schedule a weekly ${BD}muninn digest${X} ${DIM}(Mondays 08:00)${X}\n"
  printf "    --daily-hunt      also schedule a daily ${BD}geri hunt${X} ${DIM}(06:00)${X}\n"
  printf "    --dry-run, -n     print the crontab lines and change nothing\n\n"
  printf "  ${DIM}Needs the 'crontab' command; jobs fire only while the cron service is running.${X}\n\n"
}

# ── agent doc (seat an operator at the estate root — summon --agent) ──────
# render the bundled AGENTS.md template, filling in what grimnir already knows.
# uses globals AG_* set by write_agent_doc; only the installed beasts are named.
render_agents(){
  local content; content="$(cat "$1")"
  content="${content//<OWNER>/$AG_OWNER}"
  content="${content//<ROOT>/$AG_ROOT}"
  content="${content//<CONVENTIONS>/$AG_CONV}"
  content="${content//<BEASTS>/$AG_BEASTS}"
  printf '%s\n' "$content"
}
# write $ROOT/AGENTS.md (canonical) + a $ROOT/CLAUDE.md '@AGENTS.md' shim. mode: agents|claude|both.
# Never clobbers an existing AGENTS.md or a custom CLAUDE.md without --force (summon's safety ethos).
write_agent_doc(){
  local dry="$1" force="$2" mode="$3"
  local agents="$ROOT/AGENTS.md" claude="$ROOT/CLAUDE.md" tmpl
  tmpl="$(first_of "$CONV/templates/AGENTS.md" "$HERE/templates/AGENTS.md")"

  # personalization — installed beasts only, so the doc never names a tool that isn't here
  AG_OWNER="$OWNER"; AG_ROOT="$(homelit "$ROOT")"; AG_CONV="$(basename "$CONV")"
  # shellcheck disable=SC2016  # literal markdown backticks, not command substitution
  AG_BEASTS='- `grimnir`'; local b
  for b in huginn muninn geri freki; do have "$b" && AG_BEASTS="$AG_BEASTS, \`$b\`"; done

  printf "\n  ${BD}agent doc${X} ${DIM}(seat an operator at the estate root)${X}\n"
  AGENT_WROTE=0

  if [ "$mode" = agents ] || [ "$mode" = both ]; then
    if [ -z "$tmpl" ]; then
      printf "    ${R}✗ no AGENTS.md template found${X} ${DIM}(looked in %s/templates + bundled)${X}\n" "$(homelit "$CONV")"
    elif [ -f "$agents" ] && [ "$force" != 1 ]; then
      printf "    ${Y}∙${X} AGENTS.md ${DIM}exists — leaving it (--force to overwrite)${X}\n"
    elif [ "$dry" = 1 ]; then
      printf "    ${C}+ would write${X} AGENTS.md ${DIM}(%s)${X}\n" "$(homelit "$agents")"; AGENT_WROTE=1
    elif render_agents "$tmpl" > "$agents"; then
      printf "    ${G}✓ wrote${X}    AGENTS.md ${DIM}(%s)${X}\n" "$(homelit "$agents")"; AGENT_WROTE=1
    else
      printf "    ${R}✗ failed to write AGENTS.md${X}\n"
    fi
  fi

  if [ "$mode" = claude ] || [ "$mode" = both ]; then
    if [ -f "$claude" ] && grep -qx '@AGENTS.md' "$claude" 2>/dev/null; then
      printf "    ${G}✓${X} CLAUDE.md ${DIM}already → @AGENTS.md${X}\n"
    elif [ -f "$claude" ] && [ "$force" != 1 ]; then
      printf "    ${Y}∙${X} CLAUDE.md ${DIM}exists (custom) — leaving it (--force to overwrite)${X}\n"
    elif [ "$dry" = 1 ]; then
      printf "    ${C}+ would write${X} CLAUDE.md ${DIM}→ @AGENTS.md${X}\n"; AGENT_WROTE=1
    elif printf '@AGENTS.md\n' > "$claude"; then
      printf "    ${G}✓ wrote${X}    CLAUDE.md ${DIM}→ @AGENTS.md${X}\n"; AGENT_WROTE=1
    else
      printf "    ${R}✗ failed to write CLAUDE.md${X}\n"
    fi
  fi
}

# ── summon (clone-or-update every owned repo into the estate) ─────────────
# Exemptions govern management (what the beasts touch), NOT presence — summon
# deliberately brings down everything you own; it never consults is_exempt.
cmd_summon(){
  is_help "${1:-}" && { help_summon; return 0; }
  need_deps || return 1
  local UPDATE=0 DRY=0 SKIP_ARCHIVED=0 SKIP_FORKS=0 LIMIT=1000 AGENT="" FORCE=0
  while [ $# -gt 0 ]; do case "$1" in
    --update|-u)     UPDATE=1;;
    --dry-run|-n)    DRY=1;;
    --skip-archived) SKIP_ARCHIVED=1;;
    --skip-forks)    SKIP_FORKS=1;;
    --limit)         shift; LIMIT="${1:-1000}";;
    --agent)         AGENT=both;;
    --agent=*)       AGENT="${1#--agent=}";;
    --force|-f)      FORCE=1;;
    -*)              printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
    *)               printf "  ${Y}ignoring unexpected argument: %s${X}\n" "$1";;
  esac; shift; done
  case "$AGENT" in
    ""|agents|claude|both) : ;;
    *) printf "  ${Y}unknown --agent mode: %s (use agents|claude|both) — assuming both${X}\n" "$AGENT"; AGENT=both;;
  esac
  need_owner || return 1

  printf "\n  ${BD}grimnir summon${X}  ${DIM}· gather the realms · %s → %s%s${X}\n" \
    "$OWNER" "$ROOT" "$([ "$DRY" = 1 ] && echo ' · dry-run')"
  printf "  ${DIM}(network — lists every repo you own, clones the missing ones%s)${X}\n\n" \
    "$([ "$UPDATE" = 1 ] && echo ', pulls the present ones')"

  local rows
  rows="$(gh repo list "$OWNER" --limit "$LIMIT" --json name,isArchived,isFork,visibility \
    --jq '.[] | [.name,(.isArchived|tostring),(.isFork|tostring),.visibility] | @tsv' 2>/dev/null | sort)"
  if [ -z "$rows" ]; then
    printf "  ${R}couldn't list repos for %s${X} ${DIM}(network / gh auth?)${X}\n\n" "$OWNER"; return 1
  fi

  local owned=0 cloned=0 updated=0 present=0 filtered=0 dirty=0 prob=0
  local name arch fork vis
  while IFS=$'\t' read -r name arch fork vis; do
    [ -z "$name" ] && continue
    owned=$((owned+1))
    if [ "$SKIP_ARCHIVED" = 1 ] && [ "$arch" = true ]; then
      printf "  ${DIM}∙ filtered  %-28s (archived)${X}\n" "$name"; filtered=$((filtered+1)); continue
    fi
    if [ "$SKIP_FORKS" = 1 ] && [ "$fork" = true ]; then
      printf "  ${DIM}∙ filtered  %-28s (fork)${X}\n" "$name"; filtered=$((filtered+1)); continue
    fi
    local GD="$ROOT/$name"

    if [ ! -d "$GD/.git" ]; then
      # missing — clone. The default action; always safe/additive.
      if [ "$DRY" = 1 ]; then
        printf "  ${C}+ would clone${X} %-28s ${DIM}(%s)${X}\n" "$name" "$vis"; cloned=$((cloned+1))
      elif gh repo clone "$OWNER/$name" "$GD" -- -q >/dev/null 2>&1; then
        printf "  ${G}✓ cloned${X}     %-28s ${DIM}(%s)${X}\n" "$name" "$vis"; cloned=$((cloned+1))
      else
        printf "  ${R}✗ clone failed %s${X}\n" "$name"; prob=$((prob+1))
      fi
      continue
    fi

    # present locally
    present=$((present+1))
    [ "$UPDATE" != 1 ] && continue   # default: leave existing repos untouched

    # --update: freshen it, mirroring huginn sync (skip dirty, ff-only, never clobber work)
    if [ -n "$(git -C "$GD" status --porcelain 2>/dev/null)" ]; then
      printf "  ${Y}∙ dirty${X}      %-28s ${DIM}(skipped — uncommitted changes)${X}\n" "$name"; dirty=$((dirty+1)); continue
    fi
    local def; def=$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); def=${def:-main}
    if [ "$DRY" = 1 ]; then
      printf "  ${C}↓ would pull${X}  %-28s ${DIM}(%s)${X}\n" "$name" "$def"; updated=$((updated+1)); continue
    fi
    git -C "$GD" checkout -q "$def" 2>/dev/null
    if git -C "$GD" pull -q --ff-only origin "$def" >/dev/null 2>&1; then
      printf "  ${G}↓ updated${X}    %-28s ${DIM}(%s)${X}\n" "$name" "$def"; updated=$((updated+1))
    else
      printf "  ${R}✗ %s (couldn't fast-forward)${X}\n" "$name"; prob=$((prob+1))
    fi
  done <<< "$rows"

  # --agent: after the repos are on disk, seat an operator at the estate root
  [ -n "$AGENT" ] && write_agent_doc "$DRY" "$FORCE" "$AGENT"

  # summary — wording adapts to dry-run; segments only shown when meaningful
  local cverb; cverb="$([ "$DRY" = 1 ] && echo 'to clone' || echo 'cloned')"
  printf "\n  ${BD}%d owned${X} ${DIM}·${X} ${G}%d %s${X}" "$owned" "$cloned" "$cverb"
  if [ "$UPDATE" = 1 ]; then
    local uverb; uverb="$([ "$DRY" = 1 ] && echo 'to pull' || echo 'updated')"
    printf " ${DIM}·${X} ${G}%d %s${X}" "$updated" "$uverb"
    [ "$dirty" -gt 0 ] && printf " ${DIM}·${X} ${Y}%d dirty skipped${X}" "$dirty"
  else
    printf " ${DIM}·${X} ${DIM}%d present${X}" "$present"
  fi
  [ "$filtered" -gt 0 ] && printf " ${DIM}·${X} ${DIM}%d filtered${X}" "$filtered"
  [ "$prob" -gt 0 ] && printf " ${DIM}·${X} ${R}%d problem%s${X}" "$prob" "$(plural "$prob")"
  [ -n "$AGENT" ] && [ "${AGENT_WROTE:-0}" = 1 ] && printf " ${DIM}·${X} agent doc %s" "$([ "$DRY" = 1 ] && echo planned || echo written)"
  printf "\n"
  [ "$UPDATE" = 0 ] && [ "$present" -gt 0 ] && \
    printf "  ${DIM}%d repo%s already present, left untouched — 'grimnir summon --update' pulls them too${X}\n" "$present" "$(plural "$present")"
  printf "\n"
}

help_summon(){
  printf "\n  ${BD}grimnir summon${X} [--update] [--agent[=agents|claude|both]] [--force] [--skip-archived] [--skip-forks] [--limit N] [--dry-run]\n\n"
  printf "  Gather the realms — clone every repo you own into the estate. Lists all your repos\n"
  printf "  (${DIM}gh repo list${X}), clones any that aren't in ${BD}\$GRIMNIR_ROOT${X} yet, and by default leaves\n"
  printf "  the ones already there untouched. Cloning is additive and safe, so there's no\n"
  printf "  ${BD}--apply${X} gate — but ${BD}updating${X} existing repos is opt-in, behind ${BD}--update${X}, so a summon\n"
  printf "  never disturbs local work you haven't pushed.\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --update, -u     also pull repos already present — fast-forward only, skipping any\n"
  printf "                     with uncommitted changes ${DIM}(mirrors 'huginn sync')${X}\n"
  printf "    --agent[=mode]   after summoning, seat an operator at the estate root: write an\n"
  printf "                     ${BD}AGENTS.md${X} (personalized to your owner/root/installed beasts) plus a\n"
  printf "                     ${BD}CLAUDE.md${X} ${DIM}@AGENTS.md${X} shim so Claude Code picks it up too. ${DIM}mode:${X}\n"
  printf "                     ${DIM}agents (canonical only) · claude (shim only) · both (default)${X}\n"
  printf "    --force, -f      overwrite an existing AGENTS.md / custom CLAUDE.md ${DIM}(with --agent)${X}\n"
  printf "    --skip-archived  don't clone archived repos\n"
  printf "    --skip-forks     don't clone forks\n"
  printf "    --limit N        cap how many repos to list ${DIM}(default: 1000)${X}\n"
  printf "    --dry-run, -n    print the plan — what would be cloned/pulled/written — and change nothing\n\n"
  printf "  ${DIM}The agent doc is idempotent: an existing AGENTS.md is never clobbered without --force —\n"
  printf "  by then it's your hand-tuned operating doc. The template is grimnir's bundled\n"
  printf "  templates/AGENTS.md, overridable at <conventions>/templates/AGENTS.md.${X}\n\n"
  printf "  ${DIM}Exemptions govern management, not presence: summon brings down everything you own,\n"
  printf "  even repos the ravens/wolves skip when acting (a profile repo, creative repos). Network —\n"
  printf "  one 'gh repo list', then one clone or pull per repo.${X}\n\n"
}

# ── config (front-end for the shared estate config all beasts read) ───────
cmd_config(){
  is_help "${1:-}" && { help_config; return 0; }
  local sub="${1:-show}"; [ $# -gt 0 ] && shift
  case "$sub" in
    show)  config_show;;
    init)  config_init "$@";;
    set)   config_set "$@";;
    edit)  config_edit;;
    path)  printf '%s\n' "$CONFIG";;
    *)     printf "  ${R}unknown config subcommand: %s${X} ${DIM}(show · init · set · edit · path)${X}\n" "$sub"; return 1;;
  esac
}

# the front-end view — resolve the whole shared estate identity in one place
config_show(){
  local osrc="detected"
  if [ -n "${_env_OWNER:-}" ]; then osrc="env GRIMNIR_OWNER"
  elif [ -n "${GRIMNIR_OWNER:-}" ]; then osrc="grimnir config"
  elif [ -n "${HUGINN_OWNER:-}" ]; then osrc="huginn config (fallback)"; fi
  local resolved_owner="$OWNER"; [ -z "$resolved_owner" ] && resolved_owner="$(gh api user --jq .login 2>/dev/null)"

  printf "\n  ${BD}grimnir config${X}  ${DIM}· the shared estate identity every beast reads${X}\n\n"
  printf "    ${BD}owner${X}   %-28s ${DIM}(%s)${X}\n" "${resolved_owner:-${R}unset${X}}" "$osrc"
  printf "    ${BD}root${X}    %-28s ${DIM}(%s)${X}\n" "$ROOT" "$([ -d "$ROOT" ] && echo exists || echo missing)"
  printf "    ${BD}config${X}  %-28s ${DIM}(%s)${X}\n" "$(homelit "$CONFIG")" "$([ -f "$CONFIG" ] && echo exists || echo 'not written — grimnir config init')"

  printf "\n  ${BD}exemptions${X} ${DIM}· repos the beasts skip when acting (not summon/rally)${X}\n"
  local ej="$CONV/exemptions.json"
  if [ -f "$ej" ] && have jq; then
    printf "    ${DIM}source: %s${X}\n" "$(homelit "$ej")"
    while IFS=$'\t' read -r repo reason; do
      [ -z "$repo" ] && continue
      printf "    ${DIM}∙${X} %-28s ${DIM}%s${X}\n" "$repo" "$reason"
    done < <(jq -r '.exempt[] | "\(.repo)\t\(.reason)"' "$ej" 2>/dev/null)
  else
    printf "    ${DIM}none found (looked in %s)${X}\n" "$(homelit "$ej")"
  fi

  printf "\n  ${BD}beast configs on disk${X}\n    "
  local b cf
  for b in huginn muninn geri freki; do
    cf="${XDG_CONFIG_HOME:-$HOME/.config}/$b/config"
    if [ -f "$cf" ]; then printf "${G}✓${X} %s   " "$b"; else printf "${DIM}∙ %s${X}   " "$b"; fi
  done
  printf "\n\n  ${DIM}each beast reads its own config, then falls back to huginn's for owner/root —\n"
  printf "  set those once (here or in huginn's config) and the whole pack follows.${X}\n\n"
}

config_init(){
  local force=0; [ "${1:-}" = "--force" ] && force=1
  if [ -f "$CONFIG" ] && [ "$force" = 0 ]; then
    printf "\n  config already exists → ${C}%s${X}\n  ${DIM}edit it ('grimnir config edit'), or 'grimnir config init --force' to overwrite.${X}\n\n" "$CONFIG"; return 0
  fi
  write_config
  printf "\n  ${G}✓${X} wrote ${C}%s${X}\n\n" "$CONFIG"
  sed 's/^/    /' "$CONFIG"
  printf "\n  ${DIM}edit as needed — env vars (GRIMNIR_*) override the file, and any key left unset\n"
  printf "  falls back to ~/.config/huginn/config.${X}\n\n"
}

config_set(){
  local key="${1:-}" val="${2:-}"
  { [ -z "$key" ] || [ -z "$val" ]; } && { printf "  ${R}usage:${X} grimnir config set <owner|root> <value>\n"; return 1; }
  [ -f "$CONFIG" ] || write_config
  case "$key" in
    owner) upsert_config GRIMNIR_OWNER "$val";;
    root)  upsert_config GRIMNIR_ROOT "$val";;
    *)     printf "  ${R}unknown key: %s${X} ${DIM}(owner · root)${X}\n" "$key"; return 1;;
  esac
  printf "  ${G}✓${X} set ${BD}%s${X} = %s ${DIM}in %s${X}\n" "$key" "$val" "$(homelit "$CONFIG")"
}

config_edit(){
  [ -f "$CONFIG" ] || write_config
  "${EDITOR:-vi}" "$CONFIG"
}

help_config(){
  printf "\n  ${BD}grimnir config${X} [show | init [--force] | set <key> <value> | edit | path]\n\n"
  printf "  One front-end for the shared estate config every beast reads — owner, root, and the\n"
  printf "  exemptions the ravens/wolves honor. Grimnir's own config lives at\n"
  printf "  ${DIM}%s${X}; when a key is unset there, the whole pack (grimnir\n" "$(homelit "$CONFIG")"
  printf "  included) falls back to ~/.config/huginn/config — so you set the estate identity once.\n\n"
  printf "  ${BD}Subcommands${X}\n"
  printf "    show ${DIM}(default)${X}    resolve and print owner · root · config path · exemptions · beast configs\n"
  printf "    init [--force]    scaffold the config file with detected defaults ${DIM}(like a beast's 'init')${X}\n"
  printf "    set <k> <v>       set ${BD}owner${X} or ${BD}root${X} in the config file\n"
  printf "    edit              open the config in \$EDITOR ${DIM}(scaffolds it first if absent)${X}\n"
  printf "    path              print the config file path\n\n"
  printf "  ${DIM}Exemptions are read from the conventions repo (%s/exemptions.json) —\n" "$(homelit "$CONV")"
  printf "  edit them there, since they're the estate-wide standard the beasts share.${X}\n\n"
}

# ── install (wire the present pack into ~/.local/bin) ──────────────────────
cmd_install(){
  is_help "${1:-}" && { help_install; return 0; }
  local DRY=0 FORCE=0
  for a in "$@"; do case "$a" in
    --dry-run|-n) DRY=1;; --force|-f) FORCE=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}grimnir install${X}  ${DIM}· wire the pack into %s%s${X}\n\n" \
    "$(homelit "$BIN")" "$([ "$DRY" = 1 ] && echo ' · dry-run')"
  provision "$DRY" "$FORCE"

  printf "\n  ${BD}%d linked${X} ${DIM}·${X} ${G}%d already${X} ${DIM}·${X} ${DIM}%d absent${X}" "$P_LINKED" "$P_ALREADY" "$P_ABSENT"
  [ "$P_CONFLICT" -gt 0 ] && printf " ${DIM}·${X} ${Y}%d conflict%s${X}" "$P_CONFLICT" "$(plural "$P_CONFLICT")"
  [ "$P_FAILED" -gt 0 ] && printf " ${DIM}·${X} ${R}%d failed${X}" "$P_FAILED"
  printf "\n"
  [ "$P_CONFLICT" -gt 0 ] && printf "  ${DIM}%d link%s point elsewhere — 'grimnir install --force' relinks them to the estate${X}\n" "$P_CONFLICT" "$(plural "$P_CONFLICT")"
  [ "$P_ABSENT" -gt 0 ] && printf "  ${DIM}%d beast%s not in the estate — 'grimnir rally' fetches the missing ones${X}\n" "$P_ABSENT" "$(plural "$P_ABSENT")"
  printf "\n"
}

# ── rally (assemble the pack — fetch the missing beasts, then wire them up) ─
cmd_rally(){
  is_help "${1:-}" && { help_rally; return 0; }
  need_deps || return 1
  local DRY=0 FORCE=0 UPDATE=0
  for a in "$@"; do case "$a" in
    --dry-run|-n) DRY=1;; --force|-f) FORCE=1;; --update|-u) UPDATE=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done

  printf "\n  ${BD}grimnir rally${X}  ${DIM}· assemble the pack · %s → %s%s${X}\n" \
    "$PACK_OWNER" "$ROOT" "$([ "$DRY" = 1 ] && echo ' · dry-run')"
  printf "  ${DIM}(network — clones any missing beast%s, then wires the pack up)${X}\n\n" \
    "$([ "$UPDATE" = 1 ] && echo ' and pulls the present ones')"

  printf "  ${BD}the pack${X} ${DIM}(fetch from %s)${X}\n" "$PACK_OWNER"
  local name cloned=0 present=0 updated=0 dirty=0 prob=0
  for name in $BEASTS; do
    local GD="$ROOT/$name"
    if [ ! -d "$GD/.git" ]; then
      if [ "$DRY" = 1 ]; then
        printf "    ${C}+ would clone${X} %-8s ${DIM}(%s/%s)${X}\n" "$name" "$PACK_OWNER" "$name"; cloned=$((cloned+1))
      elif gh repo clone "$PACK_OWNER/$name" "$GD" -- -q >/dev/null 2>&1; then
        printf "    ${G}✓ cloned${X}   %-8s ${DIM}(%s/%s)${X}\n" "$name" "$PACK_OWNER" "$name"; cloned=$((cloned+1))
      else
        printf "    ${R}✗ clone failed %s${X} ${DIM}(no %s/%s? network?)${X}\n" "$name" "$PACK_OWNER" "$name"; prob=$((prob+1))
      fi
      continue
    fi
    # already present — idempotent by default; --update freshens it
    present=$((present+1))
    if [ "$UPDATE" != 1 ]; then
      printf "    ${G}✓${X} %-8s ${DIM}already present${X}\n" "$name"; continue
    fi
    if [ -n "$(git -C "$GD" status --porcelain 2>/dev/null)" ]; then
      printf "    ${Y}∙${X} %-8s ${DIM}dirty — skipped${X}\n" "$name"; dirty=$((dirty+1)); continue
    fi
    local def; def=$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); def=${def:-main}
    if [ "$DRY" = 1 ]; then
      printf "    ${C}↓ would pull${X}  %-8s ${DIM}(%s)${X}\n" "$name" "$def"; updated=$((updated+1)); continue
    fi
    git -C "$GD" checkout -q "$def" 2>/dev/null
    if git -C "$GD" pull -q --ff-only origin "$def" >/dev/null 2>&1; then
      printf "    ${G}↓ updated${X}  %-8s ${DIM}(%s)${X}\n" "$name" "$def"; updated=$((updated+1))
    else
      printf "    ${R}✗ %s (couldn't fast-forward)${X}\n" "$name"; prob=$((prob+1))
    fi
  done

  # wire the whole pack up (deps · symlink · config · PATH) — the same provisioner 'install' uses
  printf "\n"
  provision "$DRY" "$FORCE"

  printf "\n  ${BD}pack %s${X} ${DIM}·${X} ${G}%d %s${X} ${DIM}·${X} ${G}%d linked${X} ${DIM}·${X} ${DIM}%d already linked${X}" \
    "$([ "$DRY" = 1 ] && echo 'plan' || echo 'assembled')" \
    "$cloned" "$([ "$DRY" = 1 ] && echo 'to clone' || echo 'cloned')" "$P_LINKED" "$P_ALREADY"
  [ "$UPDATE" = 1 ] && printf " ${DIM}·${X} ${G}%d updated${X}" "$updated"
  [ "$dirty" -gt 0 ] && printf " ${DIM}·${X} ${Y}%d dirty${X}" "$dirty"
  [ "$P_CONFLICT" -gt 0 ] && printf " ${DIM}·${X} ${Y}%d link conflict%s${X}" "$P_CONFLICT" "$(plural "$P_CONFLICT")"
  local probs=$((prob + P_FAILED)); [ "$probs" -gt 0 ] && printf " ${DIM}·${X} ${R}%d problem%s${X}" "$probs" "$(plural "$probs")"
  printf "\n"
  [ "$P_CONFLICT" -gt 0 ] && printf "  ${DIM}%d link%s point elsewhere — 'grimnir rally --force' relinks them to the estate${X}\n" "$P_CONFLICT" "$(plural "$P_CONFLICT")"
  [ "$UPDATE" = 0 ] && [ "$present" -gt 0 ] && printf "  ${DIM}%d beast%s already present, left as-is — 'grimnir rally --update' pulls them to latest${X}\n" "$present" "$(plural "$present")"
  printf "\n"
}

help_install(){
  printf "\n  ${BD}grimnir install${X} [--force] [--dry-run]\n\n"
  printf "  Wire the pack into ${BD}%s${X} — symlink each beast script already present in the\n" "$(homelit "$BIN")"
  printf "  estate (${DIM}%s/<beast>/<beast>${X}), check deps, and scaffold grimnir's config. Idempotent:\n" "$(homelit "$ROOT")"
  printf "  a link that's already correct is left alone. This is the ${BD}local${X} half of provisioning —\n"
  printf "  it links what's on disk; ${BD}grimnir rally${X} fetches the beasts that aren't.\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --force, -f     relink a name whose symlink points somewhere other than the estate\n"
  printf "    --dry-run, -n   print the plan — what would be linked/scaffolded — and change nothing\n\n"
  printf "  ${DIM}Symlink target dir is \$GRIMNIR_BIN (default ~/.local/bin); make sure it's on your \$PATH.${X}\n\n"
}

help_rally(){
  printf "\n  ${BD}grimnir rally${X} [--update] [--force] [--dry-run]\n\n"
  printf "  Assemble the pack — the one-command onboarding. Clones any of the four beasts\n"
  printf "  (${BD}%s${X}) missing from the estate, from ${BD}%s${X}, then wires the whole\n" "$BEASTS" "$PACK_OWNER"
  printf "  pack up (the same deps/symlink/config step ${BD}install${X} runs). Install grimnir, run\n"
  printf "  ${BD}grimnir rally${X}, and the suite is ready.\n\n"
  printf "  ${BD}Idempotent by default${X} — a beast already present is reported and left untouched; only\n"
  printf "  missing ones are cloned. Nothing is overwritten unless you ask:\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --update, -u    also pull beasts already present to latest — fast-forward only,\n"
  printf "                    skipping any with uncommitted changes ${DIM}(mirrors 'summon --update')${X}\n"
  printf "    --force, -f     relink a name whose symlink points somewhere other than the estate\n"
  printf "    --dry-run, -n   print the whole plan — clone · pull · link — and change nothing\n\n"
  printf "  ${DIM}The beasts are fetched from \$GRIMNIR_PACK_OWNER (default %s) — the canonical\n" "$PACK_OWNER"
  printf "  source of the pack, which needn't be your own estate owner. Network — one clone per\n"
  printf "  missing beast, plus a pull per present beast under --update.${X}\n\n"
}

# ── version (every pack member's version, at a glance) ────────────────────
cmd_version(){
  is_help "${1:-}" && { help_version; return 0; }
  printf "\n  ${BD}grimnir version${X}  ${DIM}· the pack, at a glance${X}\n\n"
  local name info t ahead
  for name in grimnir $BEASTS; do
    if info="$(beast_ver "$name")"; then
      IFS=$'\x1f' read -r t ahead <<<"$info"
      if [ -z "$t" ]; then
        printf "    ${BD}%-8s${X}  ${DIM}(dev)${X}\n" "$name"
      elif [ "${ahead:-0}" -gt 0 ]; then
        printf "    ${BD}%-8s${X}  %-8s  ${DIM}+%s since${X}\n" "$name" "$t" "$ahead"
      else
        printf "    ${BD}%-8s${X}  %s\n" "$name" "$t"
      fi
    else
      printf "    ${DIM}%-8s  (not in estate)${X}\n" "$name"
    fi
  done
  printf "\n"
}

# ── doctor (self) — health-check the pack itself, not the repos ───────────
cmd_doctor(){
  is_help "${1:-}" && { help_doctor; return 0; }
  printf "\n  ${BD}grimnir doctor${X}  ${DIM}· pack health — not repo compliance (that's 'huginn doctor')${X}\n\n"

  deps_report || true
  local acct; acct="$(gh api user --jq .login 2>/dev/null)"
  if [ -n "$acct" ]; then printf "  ${BD}gh${X}    ${G}✓${X} authenticated as ${BD}%s${X}\n" "$acct"
  else printf "  ${BD}gh${X}    ${R}✗ not authenticated${X} ${DIM}(gh auth login)${X}\n"; fi
  if [ -f "$CONFIG" ]; then printf "  ${BD}config${X} ${G}✓${X} %s\n" "$(homelit "$CONFIG")"
  elif [ -f "$HCONFIG" ]; then printf "  ${BD}config${X} ${Y}∙${X} no grimnir config ${DIM}(falling back to huginn's — 'grimnir config init' to pin it)${X}\n"
  else printf "  ${BD}config${X} ${Y}∙${X} none ${DIM}('grimnir config init' scaffolds it)${X}\n"; fi
  case ":$PATH:" in
    *":$BIN:"*) printf "  ${BD}bin${X}   ${G}✓${X} %s ${DIM}(on PATH)${X}\n" "$(homelit "$BIN")";;
    *)          printf "  ${BD}bin${X}   ${Y}∙${X} %s ${DIM}(not on PATH — add it)${X}\n" "$(homelit "$BIN")";;
  esac

  printf "\n  ${BD}the pack${X}\n"
  local name info t ahead vstr where linked=0 estate=0 offpath=0 absent=0
  for name in grimnir $BEASTS; do
    local script="$ROOT/$name/$name"
    if ! info="$(beast_ver "$name")"; then
      printf "    ${DIM}∙ %-8s  not in estate${X} ${DIM}(grimnir rally)${X}\n" "$name"; absent=$((absent+1)); continue
    fi
    estate=$((estate+1))
    IFS=$'\x1f' read -r t ahead <<<"$info"; [ -z "$t" ] && t="dev"
    vstr="$t"; [ "${ahead:-0}" -gt 0 ] && vstr="$t+$ahead"
    where="$(command -v "$name" 2>/dev/null)"
    if [ -z "$where" ]; then
      printf "    ${Y}▲${X} %-8s  %-10s  ${Y}not on PATH${X} ${DIM}(grimnir install)${X}\n" "$name" "$vstr"; offpath=$((offpath+1))
    elif [ "$(readlink -f "$where" 2>/dev/null)" = "$(readlink -f "$script" 2>/dev/null)" ]; then
      printf "    ${G}✓${X} %-8s  %-10s  ${DIM}%s${X}\n" "$name" "$vstr" "$(homelit "$where")"; linked=$((linked+1))
    else
      printf "    ${Y}▲${X} %-8s  %-10s  ${Y}on PATH, not → estate${X} ${DIM}(%s · grimnir install --force)${X}\n" "$name" "$vstr" "$(homelit "$where")"; offpath=$((offpath+1))
    fi
  done

  printf "\n  ${BD}%d of %d linked from the estate${X}" "$linked" "$estate"
  [ "$offpath" -gt 0 ] && printf " ${DIM}·${X} ${Y}%d not linked${X}" "$offpath"
  [ "$absent" -gt 0 ]  && printf " ${DIM}·${X} ${DIM}%d absent${X}" "$absent"
  printf "\n\n"
}

help_version(){
  printf "\n  ${BD}grimnir version${X}\n\n"
  printf "  Every pack member's version at a glance — grimnir and the four beasts, each read from\n"
  printf "  its latest git tag (newest by semver). A repo with commits since its last tag shows\n"
  printf "  ${DIM}+N since${X}; one with no tags yet shows ${DIM}(dev)${X}; one not in the estate is marked so.\n\n"
  printf "  ${DIM}Local — derived from git tags, no stored version string ('derive, don't store',\n"
  printf "  the same approach as the rest of the pack).${X}\n\n"
}

help_doctor(){
  printf "\n  ${BD}grimnir doctor${X}\n\n"
  printf "  Health-check the ${BD}pack itself${X} — distinct from ${BD}huginn doctor${X}, which audits your repos\n"
  printf "  against conventions. Reports:\n\n"
  printf "    ${BD}deps${X}      bash · git · gh · jq present\n"
  printf "    ${BD}gh${X}        authenticated, and as who\n"
  printf "    ${BD}config${X}    grimnir's config present (or falling back to huginn's)\n"
  printf "    ${BD}bin${X}       \$GRIMNIR_BIN is on your \$PATH\n"
  printf "    ${BD}the pack${X}  per member — in the estate · version · on PATH and linked to the estate\n\n"
  printf "  A member on PATH but pointing somewhere other than the estate is flagged (repair with\n"
  printf "  ${BD}grimnir install --force${X}); one missing entirely points you at ${BD}grimnir rally${X}.\n\n"
  printf "  ${DIM}Local — reads git tags + symlink targets; one 'gh api user' for the auth line.${X}\n\n"
}

# ── help ──────────────────────────────────────────────────────────────────
cmd_help(){
  printf "\n  ${BD}grimnir${X} ${DIM}— the Allfather's high seat · %s${X}\n\n" "$ROOT"
  printf "  ${DIM}survey the estate${X}\n"
  printf "    ${BD}survey${X}                 one consolidated briefing — present · past · threats · cruft\n"
  printf "    ${BD}brief${X}                  the deltas since your last brief — a lean morning digest\n"
  printf "  ${DIM}provision${X}\n"
  printf "    ${BD}rally${X} [--update]       assemble the pack — clone the four beasts + wire them up\n"
  printf "    ${BD}install${X} [--force]      symlink the present beasts into %s\n" "$(homelit "$BIN")"
  printf "    ${BD}summon${X} [--agent]       clone every repo you own into the estate ${DIM}(--agent seats an operator)${X}\n"
  printf "  ${DIM}configure${X}\n"
  printf "    ${BD}config${X} [set|edit]      the shared estate config — owner · root · exemptions\n"
  printf "    ${BD}schedule${X} [install]     cron a daily brief to a logfile ${DIM}(+ opt-in digest / hunt)${X}\n"
  printf "  ${DIM}inspect the pack${X}\n"
  printf "    ${BD}doctor${X}                 pack health — installed · on PATH · linked · current\n"
  printf "    ${BD}version${X}                every beast's version, at a glance\n"
  printf "  ${DIM}reference${X}\n"
  printf "    ${BD}help${X}                   this menu\n\n"
  printf "  ${DIM}beasts on PATH:${X}"
  local b; for b in huginn muninn geri freki; do
    if have "$b"; then printf "  ${G}✓${X} %s" "$b"; else printf "  ${DIM}∙ %s${X}" "$b"; fi
  done
  printf "\n\n"
  printf "  ${DIM}run${X} ${BD}grimnir <command> help${X} ${DIM}for details & options on any command.${X}\n\n"
}

case "${1:-help}" in
  survey)  shift; cmd_survey "$@";;
  brief|morning) shift; cmd_brief "$@";;
  summon)  shift; cmd_summon "$@";;
  config)  shift; cmd_config "$@";;
  schedule) shift; cmd_schedule "$@";;
  install) shift; cmd_install "$@";;
  rally)   shift; cmd_rally "$@";;
  doctor)  shift; cmd_doctor "$@";;
  version|--version|-V) shift; cmd_version "$@";;
  help|-h|--help) cmd_help;;
  *) printf "${R}unknown command: %s${X}\n" "$1"; cmd_help; exit 1;;
esac
